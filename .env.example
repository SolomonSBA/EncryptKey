# --- Option A: Hosting email (recommended if CTO provides SMTP) ---
# Base URL of the contact API (see /server). No trailing slash.
# Example: https://yourdomain.com
# VITE_CONTACT_API_URL=

# --- Option B: Formspree (if not using hosting email API) ---
# Form IDs from https://formspree.io (e.g. https://formspree.io/f/xyzabc → xyzabc)
VITE_FORMSPREE_CONTACT_ID=
VITE_FORMSPREE_NEWSLETTER_ID=

# SMTP – use Secure server so TLS cert matches (mail5013.site4now.net from Email Manager)
# Do NOT use mail.encryptkey.co.uk – it causes "cert's altnames" error; use the Secure SMTP host instead
SMTP_HOST=mail5013.site4now.net
SMTP_PORT=587
SMTP_USER=info@encryptkey.co.uk
SMTP_PASS=your_mailbox_password
# If port 25 is blocked, try 8889. For SSL use port 465 and set SMTP_SECURE=true
# SMTP_SECURE=true

# Where to receive form emails – company inbox (team reads and replies from here)
CONTACT_TO_EMAIL=contact@sterlingprong.com
NEWSLETTER_TO_EMAIL=contact@sterlingprong.com

# Optional (for local dev only – do NOT set PORT on SmarterASP; the host provides it)
PORT=3000
CORS_ORIGIN=https://encryptkey.co.uk
